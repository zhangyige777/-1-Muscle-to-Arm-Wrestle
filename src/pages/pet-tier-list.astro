---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getGameConfig, getPets, generateBreadcrumbSchema, generateFAQSchema, formatNumber } from '@/lib/data';

const config = getGameConfig();
const allPets = getPets();

const tierOrder = ['S', 'A', 'B', 'C', 'D'] as const;
const tierColors: Record<string, { bg: string; border: string; text: string; badge: string; label: string }> = {
  S: { bg: 'bg-amber-50 dark:bg-amber-950/30', border: 'border-amber-300 dark:border-amber-700', text: 'text-amber-700 dark:text-amber-300', badge: 'bg-gradient-to-r from-amber-400 to-yellow-300 text-amber-900', label: 'S Tier — Best' },
  A: { bg: 'bg-purple-50 dark:bg-purple-950/30', border: 'border-purple-300 dark:border-purple-700', text: 'text-purple-700 dark:text-purple-300', badge: 'bg-gradient-to-r from-purple-500 to-purple-400 text-white', label: 'A Tier — Great' },
  B: { bg: 'bg-blue-50 dark:bg-blue-950/30', border: 'border-blue-300 dark:border-blue-700', text: 'text-blue-700 dark:text-blue-300', badge: 'bg-gradient-to-r from-blue-500 to-blue-400 text-white', label: 'B Tier — Good' },
  C: { bg: 'bg-green-50 dark:bg-green-950/30', border: 'border-green-300 dark:border-green-700', text: 'text-green-700 dark:text-green-300', badge: 'bg-gradient-to-r from-green-500 to-green-400 text-white', label: 'C Tier — Average' },
  D: { bg: 'bg-gray-50 dark:bg-gray-900/50', border: 'border-gray-300 dark:border-gray-700', text: 'text-gray-600 dark:text-gray-400', badge: 'bg-gradient-to-r from-gray-400 to-gray-300 text-gray-800', label: 'D Tier — Weak' },
};

const petsByTier: Record<string, typeof allPets> = {};
for (const tier of tierOrder) {
  petsByTier[tier] = allPets.filter(p => p.tier === tier);
}

const rarityColors: Record<string, string> = {
  Common: 'text-gray-500 dark:text-gray-400',
  Uncommon: 'text-green-600 dark:text-green-400',
  Rare: 'text-blue-600 dark:text-blue-400',
  Epic: 'text-purple-600 dark:text-purple-400',
  Legendary: 'text-amber-600 dark:text-amber-400',
  Mythical: 'text-red-600 dark:text-red-400',
};

const breadcrumbSchema = generateBreadcrumbSchema([
  { name: 'Home', url: '/' },
  { name: 'Pet Tier List', url: '/pet-tier-list' },
]);

const faqSchema = generateFAQSchema([
  {
    question: 'What is the best pet in +1 Muscle to Arm Wrestle?',
    answer: 'The Huge Hydra Dominus is the best pet, sitting alone in S Tier with an incredible x150 muscle bonus and x50 win bonus. It is a Gamepass-exclusive Mythical pet available for 329 Robux.',
  },
  {
    question: 'How are pets ranked in this tier list?',
    answer: 'Pets are ranked from S (best) to D (weakest) based on their muscle bonus multiplier and win bonus multiplier. Higher multipliers and better overall value place a pet higher in the tier list. Rarity, hatch chance, and accessibility are also considered.',
  },
  {
    question: 'Can I get S Tier and A Tier pets for free?',
    answer: 'The S Tier Huge Hydra Dominus requires a 329 Robux Gamepass purchase. However, A Tier pets like 67 and Strawberry Elephant can be hatched from in-game eggs (67 Pack and Strawberry Egg) without spending Robux, though they have very low hatch chances around 1%.',
  },
]);

const lastUpdated = config.game.lastUpdated;
---

<BaseLayout
  title="+1 Muscle to Arm Wrestle Pet Tier List (Best Pets Ranked)"
  description="Complete pet tier list for +1 Muscle to Arm Wrestle. All pets ranked from S to D tier with muscle and win bonuses compared."
  canonical="/pet-tier-list/"
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <div class="max-w-5xl mx-auto px-4 py-10">
    <!-- Breadcrumb -->
    <nav class="text-sm text-gray-400 mb-4 flex items-center gap-1">
      <a href="/" class="hover:text-blue-500">Home</a>
      <span>/</span>
      <span class="text-gray-700 dark:text-gray-300 font-medium">Pet Tier List</span>
    </nav>

    <div class="text-3xl mb-2" aria-hidden="true">🏆</div>
    <h1 class="text-3xl font-extrabold tracking-tight mb-2">+1 Muscle to Arm Wrestle Pet Tier List</h1>
    <p class="text-gray-500 mb-2">
      All {allPets.length} pets ranked from S to D tier with muscle and win bonuses compared.
    </p>
    <p class="text-xs text-gray-400 mb-8">
      Last updated: {lastUpdated}
    </p>

    <!-- Tier Legend -->
    <section class="mb-8 p-4 rounded-xl border border-gray-200 dark:border-gray-800 bg-gray-50 dark:bg-gray-900">
      <h2 class="text-sm font-bold mb-3 text-gray-600 dark:text-gray-400 uppercase tracking-wide">Tier Legend</h2>
      <div class="flex flex-wrap gap-2">
        {tierOrder.map(tier => (
          <span class={`px-3 py-1 rounded-full text-xs font-bold ${tierColors[tier].badge}`}>
            {tier} Tier
          </span>
        ))}
      </div>
    </section>

    <!-- Pet Tiers -->
    {tierOrder.map(tier => {
      const pets = petsByTier[tier];
      if (pets.length === 0) return null;
      const colors = tierColors[tier];
      return (
        <section class="mb-8">
          <div class={`flex items-center gap-3 mb-4 px-4 py-2.5 rounded-xl ${colors.bg} border ${colors.border}`}>
            <span class={`px-3 py-1 rounded-lg text-sm font-black ${colors.badge}`}>
              {tier}
            </span>
            <h2 class={`text-lg font-bold ${colors.text}`}>
              {colors.label}
            </h2>
            <span class="ml-auto text-sm text-gray-400">{pets.length} pet{pets.length !== 1 ? 's' : ''}</span>
          </div>

          <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {pets.map(pet => (
              <div class={`p-4 rounded-xl border ${colors.border} ${colors.bg} transition-shadow hover:shadow-md`}>
                <div class="flex items-center justify-between mb-3">
                  <h3 class="font-bold text-base">{pet.name}</h3>
                  <span class={`text-xs font-semibold uppercase ${rarityColors[pet.rarity] || 'text-gray-500'}`}>
                    {pet.rarity}
                  </span>
                </div>

                <p class="text-xs text-gray-500 dark:text-gray-400 mb-3 line-clamp-2">
                  {pet.description}
                </p>

                <div class="space-y-1.5 text-sm">
                  <div class="flex justify-between">
                    <span class="text-gray-500">Muscle Bonus</span>
                    <span class="font-bold text-amber-600 dark:text-amber-400">x{pet.muscleBonus}</span>
                  </div>
                  <div class="flex justify-between">
                    <span class="text-gray-500">Win Bonus</span>
                    <span class="font-bold text-blue-600 dark:text-blue-400">x{pet.winBonus}</span>
                  </div>
                  <div class="flex justify-between">
                    <span class="text-gray-500">Egg Source</span>
                    <span class="font-medium text-gray-700 dark:text-gray-300">{pet.eggSource}</span>
                  </div>
                  <div class="flex justify-between">
                    <span class="text-gray-500">Hatch Chance</span>
                    <span class="font-medium text-gray-700 dark:text-gray-300">{(pet.hatchChance * 100).toFixed(0)}%</span>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </section>
      );
    })}

    <!-- FAQ Section -->
    <section class="mb-10 p-6 rounded-xl bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-800">
      <h2 class="text-xl font-bold mb-4">❓ Pet Tier List FAQ</h2>
      <div class="space-y-4">
        <div>
          <h3 class="font-semibold mb-1">What is the best pet in +1 Muscle to Arm Wrestle?</h3>
          <p class="text-sm text-gray-600 dark:text-gray-400">
            The Huge Hydra Dominus is the best pet, sitting alone in S Tier with an incredible x150 muscle bonus and x50 win bonus. It is a Gamepass-exclusive Mythical pet available for 329 Robux.
          </p>
        </div>
        <div>
          <h3 class="font-semibold mb-1">How are pets ranked in this tier list?</h3>
          <p class="text-sm text-gray-600 dark:text-gray-400">
            Pets are ranked from S (best) to D (weakest) based on their muscle bonus multiplier and win bonus multiplier. Higher multipliers and better overall value place a pet higher in the tier list. Rarity, hatch chance, and accessibility are also considered.
          </p>
        </div>
        <div>
          <h3 class="font-semibold mb-1">Can I get S Tier and A Tier pets for free?</h3>
          <p class="text-sm text-gray-600 dark:text-gray-400">
            The S Tier Huge Hydra Dominus requires a 329 Robux Gamepass purchase. However, A Tier pets like 67 and Strawberry Elephant can be hatched from in-game eggs (67 Pack and Strawberry Egg) without spending Robux, though they have very low hatch chances around 1%.
          </p>
        </div>
      </div>
    </section>

    <!-- Related Links -->
    <section class="p-6 rounded-xl border border-gray-200 dark:border-gray-800">
      <h2 class="text-xl font-bold mb-4">Related Tools & Guides</h2>
      <div class="flex flex-wrap gap-3">
        <a href="/tier-list/" class="px-4 py-2 bg-gray-600 text-white rounded-lg font-semibold text-sm hover:bg-gray-700 transition-colors">
          🏆 Full Tier List
        </a>
        <a href="/best-pets/" class="px-4 py-2 bg-amber-500 text-white rounded-lg font-semibold text-sm hover:bg-amber-600 transition-colors">
          🐾 Best Pets Guide
        </a>
        <a href="/pet-calculator/" class="px-4 py-2 bg-purple-600 text-white rounded-lg font-semibold text-sm hover:bg-purple-700 transition-colors">
          🧮 Pet Calculator
        </a>
        <a href="/egg-calculator/" class="px-4 py-2 bg-blue-600 text-white rounded-lg font-semibold text-sm hover:bg-blue-700 transition-colors">
          🥚 Egg Calculator
        </a>
        <a href="/codes/" class="px-4 py-2 bg-green-600 text-white rounded-lg font-semibold text-sm hover:bg-green-700 transition-colors">
          🎫 Active Codes
        </a>
      </div>
    </section>
  </div>
</BaseLayout>
