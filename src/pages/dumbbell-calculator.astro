---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getGameConfig, getDumbbells, formatNumber, generateBreadcrumbSchema, generateFAQSchema, generateVideoGameSchema } from '@/lib/data';

const config = getGameConfig();
const dumbbells = getDumbbells();

const breadcrumbSchema = generateBreadcrumbSchema([
  { name: 'Home', url: '/' },
  { name: 'Dumbbell Calculator', url: '/dumbbell-calculator' },
]);
const faqSchema = generateFAQSchema([
  { question: 'Which dumbbell should I buy next in +1 Muscle to Arm Wrestle?', answer: 'Compare the cost-efficiency ratio (cost per muscle/step improvement) of each dumbbell. The best upgrade gives the biggest muscle boost relative to its cost. Use this calculator to find the optimal upgrade path.' },
  { question: 'How is cost-efficiency calculated for dumbbells?', answer: 'Cost-efficiency is the cost divided by the muscle per step improvement over the previous tier. A lower ratio means you get more value per win spent.' },
  { question: 'Are expensive dumbbells always better?', answer: 'Not always early on. A high-tier dumbbell may have great raw stats but terrible cost-efficiency if the price jump is massive. Buy the dumbbell that gives the best ROI for your current win budget.' },
]);
const videoGameSchema = generateVideoGameSchema();
---
<BaseLayout title="+1 Muscle to Arm Wrestle Dumbbell Calculator" description="Compare dumbbell upgrade value in +1 Muscle to Arm Wrestle. See cost per muscle and find the best upgrade path." canonical="/dumbbell-calculator">
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(videoGameSchema)} />

  <div class="max-w-5xl mx-auto px-4 py-10">
    <nav class="text-sm text-gray-400 mb-6" aria-label="Breadcrumb">
      <a href="/" class="hover:text-blue-500">Home</a>
      <span class="mx-2">/</span>
      <span class="text-gray-700 dark:text-gray-200 font-medium">Dumbbell Calculator</span>
    </nav>

    <h1 class="text-3xl font-extrabold tracking-tight mb-2">🏋️ Dumbbell Calculator</h1>
    <p class="text-gray-500 mb-8">Compare dumbbell upgrade value. See cost per muscle and find the best upgrade path.</p>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      <!-- Inputs -->
      <div class="space-y-6">
        <div>
          <label class="block font-bold mb-2" for="current-wins">💰 Your Current Wins</label>
          <input id="current-wins" type="number" min="0" value="5000" class="w-full p-3 rounded-lg border border-gray-200 bg-white dark:bg-gray-800 dark:border-gray-700 focus:ring-2 focus:ring-amber-400 outline-none" />
        </div>
        <div>
          <label class="block font-bold mb-2" for="current-dumbbell">🏋️ Current Dumbbell</label>
          <select id="current-dumbbell" class="w-full p-3 rounded-lg border border-gray-200 bg-white dark:bg-gray-800 dark:border-gray-700 focus:ring-2 focus:ring-amber-400 outline-none">
            {dumbbells.map(d => (
              <option value={d.id} data:tier={d.tier} data:musclePerStep={d.musclePerStep}>
                {d.name} — {d.musclePerStep} muscle/step
              </option>
            ))}
          </select>
        </div>
        <button id="calc-btn" class="w-full py-3 px-6 rounded-xl bg-amber-500 hover:bg-amber-600 text-white font-bold text-lg transition-colors">
          Calculate Best Upgrade
        </button>

        <!-- Results -->
        <div id="results-panel" class="hidden space-y-4">
          <div class="p-6 rounded-xl bg-gradient-to-br from-amber-50 to-orange-50 dark:from-amber-900/20 dark:to-orange-900/20 border text-center">
            <div class="text-sm text-gray-500 mb-1">Recommended Next Upgrade</div>
            <div id="next-upgrade" class="text-3xl font-black text-amber-500">—</div>
          </div>
          <div class="grid grid-cols-2 gap-3">
            <div class="p-4 rounded-xl bg-gray-50 dark:bg-gray-800 border text-center">
              <div class="text-xs text-gray-500">Upgrade Cost</div>
              <div id="upgrade-cost" class="text-xl font-bold">—</div>
            </div>
            <div class="p-4 rounded-xl bg-gray-50 dark:bg-gray-800 border text-center">
              <div class="text-xs text-gray-500">Muscle Gain</div>
              <div id="muscle-gain" class="text-xl font-bold">—</div>
            </div>
            <div class="p-4 rounded-xl bg-gray-50 dark:bg-gray-800 border text-center">
              <div class="text-xs text-gray-500">Wins After Purchase</div>
              <div id="wins-after" class="text-xl font-bold">—</div>
            </div>
            <div class="p-4 rounded-xl bg-gray-50 dark:bg-gray-800 border text-center">
              <div class="text-xs text-gray-500">Cost-Efficiency</div>
              <div id="cost-eff" class="text-xl font-bold">—</div>
            </div>
          </div>
          <div id="recommendation-box" class="p-4 rounded-xl bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800">
            <h3 class="font-bold mb-1">💡 Analysis</h3>
            <p id="recommendation-text" class="text-sm text-gray-600 dark:text-gray-300"></p>
          </div>
        </div>
      </div>

      <!-- Comparison Table -->
      <div class="space-y-4">
        <h2 class="text-xl font-bold">📊 All Dumbbells Comparison</h2>
        <div class="overflow-x-auto">
          <table class="w-full text-sm border-collapse">
            <thead>
              <tr class="bg-gray-100 dark:bg-gray-800">
                <th class="p-3 text-left rounded-tl-lg">Dumbbell</th>
                <th class="p-3 text-right">Muscle/Step</th>
                <th class="p-3 text-right">Cost</th>
                <th class="p-3 text-right rounded-tr-lg">Cost/Muscle</th>
              </tr>
            </thead>
            <tbody>
              {dumbbells.map((d, i) => {
                const prevDumbbell = i > 0 ? dumbbells[i - 1] : null;
                const muscleGain = prevDumbbell ? d.musclePerStep - prevDumbbell.musclePerStep : d.musclePerStep;
                const costPerMuscle = muscleGain > 0 ? (d.cost / muscleGain) : 0;
                return (
                  <tr class={`border-b border-gray-100 dark:border-gray-800 ${i % 2 === 0 ? 'bg-gray-50 dark:bg-gray-900/50' : ''}`}>
                    <td class="p-3 font-medium">{d.name}</td>
                    <td class="p-3 text-right">{formatNumber(d.musclePerStep)}</td>
                    <td class="p-3 text-right">{d.cost === 0 ? 'Free' : formatNumber(d.cost)}</td>
                    <td class="p-3 text-right">{costPerMuscle === 0 ? '—' : formatNumber(Math.round(costPerMuscle))}</td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>

        <!-- FAQ -->
        <div class="mt-8">
          <h2 class="text-xl font-bold mb-4">Frequently Asked Questions</h2>
          <div class="space-y-3">
            <details class="p-4 rounded-xl bg-gray-50 dark:bg-gray-800 border cursor-pointer">
              <summary class="font-semibold">Which dumbbell should I buy next?</summary>
              <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">Compare the cost-efficiency ratio (cost per muscle/step improvement) of each dumbbell. The best upgrade gives the biggest muscle boost relative to its cost. Use this calculator to find the optimal upgrade path.</p>
            </details>
            <details class="p-4 rounded-xl bg-gray-50 dark:bg-gray-800 border cursor-pointer">
              <summary class="font-semibold">How is cost-efficiency calculated for dumbbells?</summary>
              <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">Cost-efficiency is the cost divided by the muscle per step improvement over the previous tier. A lower ratio means you get more value per win spent.</p>
            </details>
            <details class="p-4 rounded-xl bg-gray-50 dark:bg-gray-800 border cursor-pointer">
              <summary class="font-semibold">Are expensive dumbbells always better?</summary>
              <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">Not always early on. A high-tier dumbbell may have great raw stats but terrible cost-efficiency if the price jump is massive. Buy the dumbbell that gives the best ROI for your current win budget.</p>
            </details>
          </div>
        </div>
      </div>
    </div>

    <!-- Related Links -->
    <div class="mt-12 pt-8 border-t">
      <h3 class="font-bold mb-4">Useful Links</h3>
      <div class="flex flex-wrap gap-3">
        <a href="/calculator/" class="px-4 py-2 rounded-lg bg-gray-100 dark:bg-gray-800 hover:bg-amber-100 dark:hover:bg-amber-900/30 font-medium text-sm transition-colors">🧮 Muscle Calculator</a>
        <a href="/wiki/" class="px-4 py-2 rounded-lg bg-gray-100 dark:bg-gray-800 hover:bg-amber-100 dark:hover:bg-amber-900/30 font-medium text-sm transition-colors">📚 Wiki</a>
        <a href="/beginner-guide/" class="px-4 py-2 rounded-lg bg-gray-100 dark:bg-gray-800 hover:bg-amber-100 dark:hover:bg-amber-900/30 font-medium text-sm transition-colors">📖 Beginner Guide</a>
      </div>
    </div>

    <p class="mt-6 text-xs text-gray-400">Last updated: {config.game.lastUpdated}</p>
  </div>

  <script define:vars={{ dumbbells }}>
    function formatNumber(num) {
      if (num >= 1e15) return (num / 1e15).toFixed(1) + 'Q';
      if (num >= 1e12) return (num / 1e12).toFixed(1) + 'T';
      if (num >= 1e9) return (num / 1e9).toFixed(1) + 'B';
      if (num >= 1e6) return (num / 1e6).toFixed(1) + 'M';
      if (num >= 1e3) return (num / 1e3).toFixed(1) + 'K';
      return num.toString();
    }

    document.getElementById('calc-btn').addEventListener('click', () => {
      const wins = parseFloat(document.getElementById('current-wins').value) || 0;
      const dbSel = document.getElementById('current-dumbbell');
      const dbOpt = dbSel.options[dbSel.selectedIndex];
      const currentTier = parseInt(dbOpt.dataset.tier);
      const currentMPS = parseFloat(dbOpt.dataset.muscleperstep);

      const nextDumbbell = dumbbells.find(d => d.tier === currentTier + 1);
      const panel = document.getElementById('results-panel');
      panel.classList.remove('hidden');

      if (!nextDumbbell) {
        document.getElementById('next-upgrade').textContent = 'MAX LEVEL';
        document.getElementById('upgrade-cost').textContent = '—';
        document.getElementById('muscle-gain').textContent = '—';
        document.getElementById('wins-after').textContent = '—';
        document.getElementById('cost-eff').textContent = '—';
        document.getElementById('recommendation-text').textContent = 'You already have the best dumbbell! No further upgrades available.';
        return;
      }

      const muscleGain = nextDumbbell.musclePerStep - currentMPS;
      const costPerMuscle = muscleGain > 0 ? (nextDumbbell.cost / muscleGain) : 0;
      const canAfford = wins >= nextDumbbell.cost;

      document.getElementById('next-upgrade').textContent = nextDumbbell.name;
      document.getElementById('upgrade-cost').textContent = formatNumber(nextDumbbell.cost);
      document.getElementById('muscle-gain').textContent = '+' + formatNumber(muscleGain) + '/step';
      document.getElementById('wins-after').textContent = canAfford ? formatNumber(wins - nextDumbbell.cost) : 'Need ' + formatNumber(nextDumbbell.cost - wins) + ' more';
      document.getElementById('cost-eff').textContent = costPerMuscle > 0 ? formatNumber(Math.round(costPerMuscle)) + '/muscle' : '—';

      let rec = '';
      if (canAfford) {
        rec = `You can afford ${nextDumbbell.name}! Upgrading gives +${formatNumber(muscleGain)} muscle per step (${(muscleGain / currentMPS * 100).toFixed(0)}% boost). `;
        // Check if skipping ahead is better
        const futureUpgrades = dumbbells.filter(d => d.tier > currentTier && d.cost <= wins);
        if (futureUpgrades.length > 1) {
          const bestValue = futureUpgrades.reduce((best, d) => {
            const gain = d.musclePerStep - currentMPS;
            const eff = gain > 0 ? d.cost / gain : Infinity;
            return eff < best.eff ? { d, eff, gain } : best;
          }, { d: null, eff: Infinity, gain: 0 });
          if (bestValue.d && bestValue.d.tier !== currentTier + 1) {
            rec += `Tip: Consider saving for ${bestValue.d.name} instead — it has better cost-efficiency at ${formatNumber(Math.round(bestValue.eff))}/muscle.`;
          } else {
            rec += 'This is the best value upgrade available to you right now.';
          }
        } else {
          rec += 'This is the best value upgrade available to you right now.';
        }
      } else {
        rec = `You need ${formatNumber(nextDumbbell.cost - wins)} more wins to afford ${nextDumbbell.name}. Keep farming!`;
      }
      document.getElementById('recommendation-text').textContent = rec;
    });
  </script>
</BaseLayout>
