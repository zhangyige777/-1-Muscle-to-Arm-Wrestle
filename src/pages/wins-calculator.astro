---
import BaseLayout from '@/layouts/BaseLayout.astro';
import AdSlot from '@/components/AdSlot.astro';
import { getGameConfig, getWorlds, formatNumber, generateBreadcrumbSchema, generateFAQSchema, generateVideoGameSchema } from '@/lib/data';

const config = getGameConfig();
const worlds = getWorlds();

const allOpponents = worlds.flatMap(w =>
  w.opponents.map(o => ({
    ...o,
    worldName: w.name,
    worldSlug: w.slug,
  }))
);

const breadcrumbSchema = generateBreadcrumbSchema([
  { name: 'Home', url: '/' },
  { name: 'Wins Calculator', url: '/wins-calculator' },
]);
const faqSchema = generateFAQSchema([
  { question: 'How are wins calculated in +1 Muscle to Arm Wrestle?', answer: 'Each opponent requires a certain amount of muscle to beat and rewards a fixed number of wins. You earn wins by arm wrestling opponents -the stronger the opponent, the more wins you get per match.' },
  { question: 'Which opponent gives the most wins per match?', answer: 'The Green Alien in Cyber City gives 10B wins per match, but requires 79Q muscle. Choose opponents you can consistently beat for the best farming efficiency.' },
  { question: 'How many matches do I need for a specific win goal?', answer: 'Divide your target wins by the wins reward of your chosen opponent. For example, to reach 1,000 wins fighting Big Bully (15 wins/match), you need about 67 matches.' },
]);
const videoGameSchema = generateVideoGameSchema();
---
<BaseLayout title="+1 Muscle to Arm Wrestle Wins Calculator" description="Calculate how many wins and matches you need in +1 Muscle to Arm Wrestle. Compare opponents and find the fastest farming route." canonical="/wins-calculator/">
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(videoGameSchema)} />

  <div class="max-w-5xl mx-auto px-4 py-10">
    <!-- Breadcrumb -->
    <nav class="text-sm text-gray-400 mb-6" aria-label="Breadcrumb">
      <a href="/" class="hover:text-blue-500">Home</a>
      <span class="mx-2">/</span>
      <span class="text-gray-700 dark:text-gray-200 font-medium">Wins Calculator</span>
    </nav>

    <div class="text-3xl mb-2" aria-hidden="true">馃弳</div>
    <h1 class="text-3xl font-extrabold tracking-tight mb-2">+1 Muscle to Arm Wrestle Wins Calculator</h1>
    <p class="text-gray-500 mb-8">Calculate how many wins and matches you need. Compare opponents and find the fastest farming route.</p>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      <!-- Inputs -->
      <div class="space-y-6">
        <div>
          <label class="block font-bold mb-2" for="muscle-input">馃挭 Your Current Muscle</label>
          <input id="muscle-input" type="number" min="0" value="1000" class="w-full p-3 rounded-lg border border-gray-200 bg-white dark:bg-gray-800 dark:border-gray-700 focus:ring-2 focus:ring-amber-400 outline-none" />
        </div>
        <div>
          <label class="block font-bold mb-2" for="wins-goal">馃幆 Goal Wins</label>
          <input id="wins-goal" type="number" min="1" value="10000" class="w-full p-3 rounded-lg border border-gray-200 bg-white dark:bg-gray-800 dark:border-gray-700 focus:ring-2 focus:ring-amber-400 outline-none" />
        </div>
        <div>
          <label class="block font-bold mb-2" for="opponent-select">馃ぜ Select Opponent</label>
          <select id="opponent-select" class="w-full p-3 rounded-lg border border-gray-200 bg-white dark:bg-gray-800 dark:border-gray-700 focus:ring-2 focus:ring-amber-400 outline-none">
            {allOpponents.map(o => (
              <option value={o.id} data:muscleRequired={o.muscleRequired} data:winsReward={o.winsReward} data:worldName={o.worldName}>
                {o.name} ({o.worldName}) -{o.winsReward} wins
              </option>
            ))}
          </select>
        </div>
        <button id="calc-btn" class="w-full py-3 px-6 rounded-xl bg-amber-500 hover:bg-amber-600 text-white font-bold text-lg transition-colors">
          Calculate
        </button>
      </div>

      <!-- Results -->
      <div class="space-y-4">
        <div id="results-panel" class="hidden space-y-4">
          <div class="p-6 rounded-xl bg-gradient-to-br from-amber-50 to-orange-50 dark:from-amber-900/20 dark:to-orange-900/20 border text-center">
            <div class="text-sm text-gray-500 mb-1">Matches Needed</div>
            <div id="matches-result" class="text-5xl font-black text-amber-500">-</div>
          </div>
          <div class="grid grid-cols-2 gap-3">
            <div class="p-4 rounded-xl bg-gray-50 dark:bg-gray-800 border text-center">
              <div class="text-xs text-gray-500">Goal Wins</div>
              <div id="goal-result" class="text-xl font-bold">-</div>
            </div>
            <div class="p-4 rounded-xl bg-gray-50 dark:bg-gray-800 border text-center">
              <div class="text-xs text-gray-500">Wins / Match</div>
              <div id="wpm-result" class="text-xl font-bold">-</div>
            </div>
            <div class="p-4 rounded-xl bg-gray-50 dark:bg-gray-800 border text-center">
              <div class="text-xs text-gray-500">Muscle Required</div>
              <div id="muscle-req-result" class="text-xl font-bold">-</div>
            </div>
            <div class="p-4 rounded-xl bg-gray-50 dark:bg-gray-800 border text-center">
              <div class="text-xs text-gray-500">Your Muscle</div>
              <div id="your-muscle-result" class="text-xl font-bold">-</div>
            </div>
          </div>
          <div id="recommendation-box" class="p-4 rounded-xl bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800">
            <h3 class="font-bold mb-1">馃挕 Recommendation</h3>
            <p id="recommendation-text" class="text-sm text-gray-600 dark:text-gray-300"></p>
          </div>
        </div>

        <!-- FAQ -->
        <div class="mt-8">
          <h2 class="text-xl font-bold mb-4">Frequently Asked Questions</h2>
          <div class="space-y-3">
            <details class="p-4 rounded-xl bg-gray-50 dark:bg-gray-800 border cursor-pointer">
              <summary class="font-semibold">How are wins calculated in +1 Muscle to Arm Wrestle?</summary>
              <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">Each opponent requires a certain amount of muscle to beat and rewards a fixed number of wins. You earn wins by arm wrestling opponents -the stronger the opponent, the more wins you get per match.</p>
            </details>
            <details class="p-4 rounded-xl bg-gray-50 dark:bg-gray-800 border cursor-pointer">
              <summary class="font-semibold">Which opponent gives the most wins per match?</summary>
              <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">The Green Alien in Cyber City gives 10B wins per match, but requires 79Q muscle. Choose opponents you can consistently beat for the best farming efficiency.</p>
            </details>
            <details class="p-4 rounded-xl bg-gray-50 dark:bg-gray-800 border cursor-pointer">
              <summary class="font-semibold">How many matches do I need for a specific win goal?</summary>
              <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">Divide your target wins by the wins reward of your chosen opponent. For example, to reach 1,000 wins fighting Big Bully (15 wins/match), you need about 67 matches.</p>
            </details>
          </div>
        </div>
      </div>
    </div>

    <AdSlot />

    <!-- Related Links -->
    <div class="mt-12 pt-8 border-t">
      <h3 class="font-bold mb-4">Useful Links</h3>
      <div class="flex flex-wrap gap-3">
        <a href="/codes/" class="px-4 py-2 rounded-lg bg-gray-100 dark:bg-gray-800 hover:bg-amber-100 dark:hover:bg-amber-900/30 font-medium text-sm transition-colors">馃巵 Codes</a>
        <a href="/muscle-calculator/" class="px-4 py-2 rounded-lg bg-gray-100 dark:bg-gray-800 hover:bg-amber-100 dark:hover:bg-amber-900/30 font-medium text-sm transition-colors">馃М Muscle Calculator</a>
        <a href="/pet-tier-list/" class="px-4 py-2 rounded-lg bg-gray-100 dark:bg-gray-800 hover:bg-amber-100 dark:hover:bg-amber-900/30 font-medium text-sm transition-colors">馃搳 Tier List</a>
      </div>
    </div>

    <p class="mt-6 text-xs text-gray-400">Last updated: {config.game.lastUpdated}</p>
  </div>

  <script define:vars={{ allOpponents }}>
    function formatNumber(num) {
      if (num >= 1e15) return (num / 1e15).toFixed(1) + 'Q';
      if (num >= 1e12) return (num / 1e12).toFixed(1) + 'T';
      if (num >= 1e9) return (num / 1e9).toFixed(1) + 'B';
      if (num >= 1e6) return (num / 1e6).toFixed(1) + 'M';
      if (num >= 1e3) return (num / 1e3).toFixed(1) + 'K';
      return num.toString();
    }

    const calcBtn = document.getElementById('calc-btn');
    const resultsPanel = document.getElementById('results-panel');

    calcBtn.addEventListener('click', () => {
      const muscle = parseFloat(document.getElementById('muscle-input').value) || 0;
      const goalWins = parseFloat(document.getElementById('wins-goal').value) || 0;
      const sel = document.getElementById('opponent-select');
      const opt = sel.options[sel.selectedIndex];
      const muscleRequired = parseFloat(opt.dataset.musclerequired) || 0;
      const winsReward = parseFloat(opt.dataset.winsreward) || 0;
      const oppName = opt.textContent.split('(')[0].trim();

      const matchesNeeded = winsReward > 0 ? Math.ceil(goalWins / winsReward) : 0;
      const canBeat = muscle >= muscleRequired;

      resultsPanel.classList.remove('hidden');
      document.getElementById('matches-result').textContent = formatNumber(matchesNeeded);
      document.getElementById('goal-result').textContent = formatNumber(goalWins);
      document.getElementById('wpm-result').textContent = formatNumber(winsReward);
      document.getElementById('muscle-req-result').textContent = formatNumber(muscleRequired);
      document.getElementById('your-muscle-result').textContent = formatNumber(muscle);

      // Find best beatable opponent
      const beatable = allOpponents.filter(o => muscle >= o.muscleRequired);
      let rec = '';
      if (!canBeat) {
        rec = `You need ${formatNumber(muscleRequired)} muscle to beat ${oppName}. Keep training!`;
        if (beatable.length > 0) {
          const best = beatable.reduce((a, b) => b.winsReward > a.winsReward ? b : a);
          rec += ` Your best available opponent is ${best.name} (${formatNumber(best.winsReward)} wins/match).`;
        }
      } else {
        rec = `You can beat ${oppName}! It will take about ${formatNumber(matchesNeeded)} matches to reach ${formatNumber(goalWins)} wins.`;
        if (beatable.length > 1) {
          const best = beatable.reduce((a, b) => b.winsReward > a.winsReward ? b : a);
          if (best.id !== sel.value) {
            const bestMatches = Math.ceil(goalWins / best.winsReward);
            rec += ` Tip: ${best.name} gives more wins (${formatNumber(best.winsReward)}/match) -only ${formatNumber(bestMatches)} matches needed!`;
          }
        }
      }
      document.getElementById('recommendation-text').textContent = rec;
    });
  </script>
</BaseLayout>
