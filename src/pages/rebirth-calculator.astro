---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getGameConfig, getRebirthTiers, getDumbbells, getPets, formatNumber, generateBreadcrumbSchema, generateFAQSchema, generateVideoGameSchema } from '@/lib/data';

const config = getGameConfig();
const rebirthTiers = getRebirthTiers();
const dumbbells = getDumbbells();
const pets = getPets();

const breadcrumbSchema = generateBreadcrumbSchema([
  { name: 'Home', url: '/' },
  { name: 'Rebirth Calculator', url: '/rebirth-calculator' },
]);
const faqSchema = generateFAQSchema([
  { question: 'When should I rebirth in +1 Muscle to Arm Wrestle?', answer: 'You should rebirth when your current muscle exceeds the break-even threshold -the point where the multiplier gain from rebirth offsets the muscle you lose. This calculator helps you find that exact point.' },
  { question: 'What do rebirth multipliers do?', answer: 'Rebirth multipliers increase your muscle per step and wins per match. Higher rebirth levels give bigger multipliers but cost exponentially more muscle to reach.' },
  { question: 'Do I lose all my muscle when I rebirth?', answer: 'Yes, rebirth resets your muscle to zero, but you gain permanent multipliers that make regaining muscle much faster. The key is rebirthing at the right time for maximum efficiency.' },
]);
const videoGameSchema = generateVideoGameSchema();
---
<BaseLayout title="+1 Muscle to Arm Wrestle Rebirth Calculator" description="Should you rebirth now or wait? Calculate the optimal rebirth timing in +1 Muscle to Arm Wrestle with break-even analysis." canonical="/rebirth-calculator/">
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(videoGameSchema)} />

  <div class="max-w-5xl mx-auto px-4 py-10">
    <nav class="text-sm text-gray-400 mb-6" aria-label="Breadcrumb">
      <a href="/" class="hover:text-blue-500">Home</a>
      <span class="mx-2">/</span>
      <span class="text-gray-700 dark:text-gray-200 font-medium">Rebirth Calculator</span>
    </nav>

    <div class="text-3xl mb-2" aria-hidden="true">馃攧</div>
    <h1 class="text-3xl font-extrabold tracking-tight mb-2">+1 Muscle to Arm Wrestle Rebirth Calculator</h1>
    <p class="text-gray-500 mb-8">Should you rebirth now or wait? Calculate the optimal rebirth timing with break-even analysis.</p>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      <!-- Inputs -->
      <div class="space-y-6">
        <div>
          <label class="block font-bold mb-2" for="rebirth-level">馃攧 Current Rebirth Level</label>
          <select id="rebirth-level" class="w-full p-3 rounded-lg border border-gray-200 bg-white dark:bg-gray-800 dark:border-gray-700 focus:ring-2 focus:ring-amber-400 outline-none">
            {rebirthTiers.map(t => (
              <option value={t.level} data:mult={t.muscleMultiplier} data:winMult={t.winMultiplier} data:cost={t.muscleCost}>
                Rebirth {t.level} -{t.muscleMultiplier}x Muscle, {t.winMultiplier}x Wins (Cost: {t.muscleCost})
              </option>
            ))}
          </select>
        </div>
        <div>
          <label class="block font-bold mb-2" for="current-muscle">馃挭 Current Muscle</label>
          <input id="current-muscle" type="number" min="0" value="1000000" class="w-full p-3 rounded-lg border border-gray-200 bg-white dark:bg-gray-800 dark:border-gray-700 focus:ring-2 focus:ring-amber-400 outline-none" />
        </div>
        <div>
          <label class="block font-bold mb-2" for="dumbbell-select">馃弸锔?Current Dumbbell</label>
          <select id="dumbbell-select" class="w-full p-3 rounded-lg border border-gray-200 bg-white dark:bg-gray-800 dark:border-gray-700 focus:ring-2 focus:ring-amber-400 outline-none">
            {dumbbells.map(d => (
              <option value={d.id} data:musclePerStep={d.musclePerStep}>
                {d.name} -{d.musclePerStep} muscle/step
              </option>
            ))}
          </select>
        </div>
        <div>
          <label class="block font-bold mb-2" for="pet-select">馃惥 Current Pet</label>
          <select id="pet-select" class="w-full p-3 rounded-lg border border-gray-200 bg-white dark:bg-gray-800 dark:border-gray-700 focus:ring-2 focus:ring-amber-400 outline-none">
            <option value="" data:bonus="1">No Pet (1x)</option>
            {pets.map(p => (
              <option value={p.id} data:bonus={p.muscleBonus}>
                {p.name} ({p.rarity}) -{p.muscleBonus}x
              </option>
            ))}
          </select>
        </div>
        <button id="calc-btn" class="w-full py-3 px-6 rounded-xl bg-amber-500 hover:bg-amber-600 text-white font-bold text-lg transition-colors">
          Analyze Rebirth
        </button>
      </div>

      <!-- Results -->
      <div class="space-y-4">
        <div id="results-panel" class="hidden space-y-4">
          <div class="p-6 rounded-xl bg-gradient-to-br from-purple-50 to-indigo-50 dark:from-purple-900/20 dark:to-indigo-900/20 border text-center">
            <div class="text-sm text-gray-500 mb-1">Recommendation</div>
            <div id="verdict" class="text-3xl font-black">-</div>
          </div>
          <div class="grid grid-cols-2 gap-3">
            <div class="p-4 rounded-xl bg-gray-50 dark:bg-gray-800 border text-center">
              <div class="text-xs text-gray-500">Next Rebirth Mult</div>
              <div id="next-mult-result" class="text-xl font-bold">-</div>
            </div>
            <div class="p-4 rounded-xl bg-gray-50 dark:bg-gray-800 border text-center">
              <div class="text-xs text-gray-500">Break-Even Muscle</div>
              <div id="breakeven-result" class="text-xl font-bold">-</div>
            </div>
            <div class="p-4 rounded-xl bg-gray-50 dark:bg-gray-800 border text-center">
              <div class="text-xs text-gray-500">Current Muscle/Step</div>
              <div id="current-mps-result" class="text-xl font-bold">-</div>
            </div>
            <div class="p-4 rounded-xl bg-gray-50 dark:bg-gray-800 border text-center">
              <div class="text-xs text-gray-500">After Rebirth Muscle/Step</div>
              <div id="new-mps-result" class="text-xl font-bold">-</div>
            </div>
          </div>
          <div id="detail-box" class="p-4 rounded-xl bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800">
            <h3 class="font-bold mb-1">馃搵 Break-Even Analysis</h3>
            <p id="detail-text" class="text-sm text-gray-600 dark:text-gray-300"></p>
          </div>
        </div>

        <div class="mt-8">
          <h2 class="text-xl font-bold mb-4">Rebirth Tiers Overview</h2>
          <div class="overflow-x-auto">
            <table class="w-full text-sm border-collapse">
              <thead>
                <tr class="bg-gray-100 dark:bg-gray-800">
                  <th class="p-3 text-left rounded-tl-lg">Level</th>
                  <th class="p-3 text-left">Muscle Mult</th>
                  <th class="p-3 text-left">Win Mult</th>
                  <th class="p-3 text-right rounded-tr-lg">Cost</th>
                </tr>
              </thead>
              <tbody>
                {rebirthTiers.map((t, i) => (
                  <tr class={`border-b border-gray-100 dark:border-gray-800 ${i % 2 === 0 ? 'bg-gray-50 dark:bg-gray-900/50' : ''}`}>
                    <td class="p-3 font-medium">{t.level}</td>
                    <td class="p-3">{t.muscleMultiplier}x</td>
                    <td class="p-3">{t.winMultiplier}x</td>
                    <td class="p-3 text-right">{t.muscleCost}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>

        <!-- FAQ -->
        <div class="mt-8">
          <h2 class="text-xl font-bold mb-4">Frequently Asked Questions</h2>
          <div class="space-y-3">
            <details class="p-4 rounded-xl bg-gray-50 dark:bg-gray-800 border cursor-pointer">
              <summary class="font-semibold">When should I rebirth in +1 Muscle to Arm Wrestle?</summary>
              <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">You should rebirth when your current muscle exceeds the break-even threshold -the point where the multiplier gain from rebirth offsets the muscle you lose. This calculator helps you find that exact point.</p>
            </details>
            <details class="p-4 rounded-xl bg-gray-50 dark:bg-gray-800 border cursor-pointer">
              <summary class="font-semibold">What do rebirth multipliers do?</summary>
              <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">Rebirth multipliers increase your muscle per step and wins per match. Higher rebirth levels give bigger multipliers but cost exponentially more muscle to reach.</p>
            </details>
            <details class="p-4 rounded-xl bg-gray-50 dark:bg-gray-800 border cursor-pointer">
              <summary class="font-semibold">Do I lose all my muscle when I rebirth?</summary>
              <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">Yes, rebirth resets your muscle to zero, but you gain permanent multipliers that make regaining muscle much faster. The key is rebirthing at the right time for maximum efficiency.</p>
            </details>
          </div>
        </div>
      </div>
    </div>

    <!-- Related Links -->
    <div class="mt-12 pt-8 border-t">
      <h3 class="font-bold mb-4">Useful Links</h3>
      <div class="flex flex-wrap gap-3">
        <a href="/muscle-calculator/" class="px-4 py-2 rounded-lg bg-gray-100 dark:bg-gray-800 hover:bg-amber-100 dark:hover:bg-amber-900/30 font-medium text-sm transition-colors">馃М Muscle Calculator</a>
        <a href="/beginner-guide/" class="px-4 py-2 rounded-lg bg-gray-100 dark:bg-gray-800 hover:bg-amber-100 dark:hover:bg-amber-900/30 font-medium text-sm transition-colors">馃摉 Beginner Guide</a>
        <a href="/pet-tier-list/" class="px-4 py-2 rounded-lg bg-gray-100 dark:bg-gray-800 hover:bg-amber-100 dark:hover:bg-amber-900/30 font-medium text-sm transition-colors">馃搳 Tier List</a>
      </div>
    </div>

    <p class="mt-6 text-xs text-gray-400">Last updated: {config.game.lastUpdated}</p>
  </div>

  <script define:vars={{ rebirthTiers }}>
    function formatNumber(num) {
      if (num >= 1e15) return (num / 1e15).toFixed(1) + 'Q';
      if (num >= 1e12) return (num / 1e12).toFixed(1) + 'T';
      if (num >= 1e9) return (num / 1e9).toFixed(1) + 'B';
      if (num >= 1e6) return (num / 1e6).toFixed(1) + 'M';
      if (num >= 1e3) return (num / 1e3).toFixed(1) + 'K';
      return num.toString();
    }

    document.getElementById('calc-btn').addEventListener('click', () => {
      const muscle = parseFloat(document.getElementById('current-muscle').value) || 0;
      const sel = document.getElementById('rebirth-level');
      const opt = sel.options[sel.selectedIndex];
      const currentLevel = parseInt(opt.value);
      const currentMult = parseFloat(opt.dataset.mult);
      const currentWinMult = parseFloat(opt.dataset.winmult);

      const dbSel = document.getElementById('dumbbell-select');
      const dbOpt = dbSel.options[dbSel.selectedIndex];
      const baseMPS = parseFloat(dbOpt.dataset.muscleperstep);

      const petSel = document.getElementById('pet-select');
      const petOpt = petSel.options[petSel.selectedIndex];
      const petBonus = parseFloat(petOpt.dataset.bonus);

      // Find next rebirth tier
      const nextTier = rebirthTiers.find(t => t.level > currentLevel);
      const nextMult = nextTier ? nextTier.muscleMultiplier : currentMult;

      const currentMPS = baseMPS * currentMult * petBonus;
      const newMPS = baseMPS * nextMult * petBonus;

      // Break-even: muscle where newMPS * steps = currentMult * steps
      // After rebirth, you start at 0 muscle. To get back to current muscle:
      // steps needed = muscle / newMPS (with new mult)
      // vs steps you've already taken were done with old mult
      // Break-even threshold: the muscle where nextMult / currentMult > muscle loss / regen time
      const multRatio = nextMult / currentMult;
      const breakEven = muscle * (1 - (1 / multRatio));
      // Simplified: you should rebirth when new mult saves more time than lost muscle costs
      const breakEvenMuscle = Math.max(0, breakEven);

      const panel = document.getElementById('results-panel');
      panel.classList.remove('hidden');

      document.getElementById('next-mult-result').textContent = nextMult + 'x';
      document.getElementById('breakeven-result').textContent = formatNumber(Math.round(breakEvenMuscle));
      document.getElementById('current-mps-result').textContent = formatNumber(currentMPS);
      document.getElementById('new-mps-result').textContent = formatNumber(newMPS);

      const verdictEl = document.getElementById('verdict');
      const detailEl = document.getElementById('detail-text');

      if (!nextTier) {
        verdictEl.textContent = 'MAX LEVEL';
        verdictEl.className = 'text-3xl font-black text-gray-500';
        detailEl.textContent = 'You are at the maximum rebirth level. No further rebirths available!';
      } else if (muscle > breakEvenMuscle && multRatio > 1) {
        verdictEl.textContent = '鉁?REBIRTH NOW';
        verdictEl.className = 'text-3xl font-black text-green-500';
        detailEl.textContent = `Your muscle (${formatNumber(muscle)}) exceeds the break-even threshold (${formatNumber(Math.round(breakEvenMuscle))}). Rebirth to Rebirth ${nextTier.level} for ${nextMult}x muscle multiplier (up from ${currentMult}x). Your new muscle/step will be ${formatNumber(newMPS)} instead of ${formatNumber(currentMPS)}.`;
      } else {
        verdictEl.textContent = '鈴?WAIT';
        verdictEl.className = 'text-3xl font-black text-amber-500';
        detailEl.textContent = `You need ${formatNumber(Math.round(breakEvenMuscle))} muscle to break even on this rebirth. Currently at ${formatNumber(muscle)}. Keep building muscle before rebirthing to Rebirth ${nextTier.level}.`;
      }
    });
  </script>
</BaseLayout>
