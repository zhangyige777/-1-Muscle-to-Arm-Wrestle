---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getGameConfig, getDumbbells, getPets, getRebirthTiers, formatNumber, generateBreadcrumbSchema, generateFAQSchema } from '@/lib/data';

const config = getGameConfig();
const dumbbells = getDumbbells();
const pets = getPets();
const rebirthTiers = getRebirthTiers();

const topMusclePets = [...pets].sort((a, b) => b.muscleBonus - a.muscleBonus).slice(0, 5);

const breadcrumbSchema = generateBreadcrumbSchema([
  { name: 'Home', url: '/' },
  { name: 'How to Get Muscle Fast', url: '/how-to-get-muscle-fast' },
]);
const faqSchema = generateFAQSchema([
  { question: 'What is the fastest way to gain muscle in +1 Muscle to Arm Wrestle?', answer: 'The fastest way to gain muscle is by stacking all four multiplier sources: the best dumbbell you can afford, your strongest pet with a high muscleBonus, the highest rebirth level you have reached, and temporary 2x boosts. All multipliers stack multiplicatively, so upgrading each one has a compounding effect.' },
  { question: 'Which dumbbell should I upgrade to first?', answer: 'Upgrade to the next available dumbbell as soon as you can afford it. Each dumbbell tier provides a significant jump in muscle per step. The Iron Dumbbell (100 Wins) doubles your gains, and the Golden Dumbbell (10K Wins) gives 12x. Always prioritize dumbbell upgrades over pet eggs in early game.' },
  { question: 'How do rebirth multipliers affect muscle gain?', answer: 'Rebirth multipliers are applied to every step you take. At Rebirth Level 5, every step gives 5x more muscle. Combined with a dumbbell (e.g., 75x) and a pet (e.g., 3x), your total multiplier becomes 5 x 75 x 3 = 1,125x per step. Higher rebirth levels are the biggest long-term power spike.' },
]);
---
<BaseLayout title="+1 Muscle to Arm Wrestle How to Get Muscle Fast" description="Fastest ways to gain muscle in +1 Muscle to Arm Wrestle. Dumbbell upgrades, pet multipliers, rebirth bonuses, and boost strategies." canonical="/how-to-get-muscle-fast">
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <div class="max-w-4xl mx-auto px-4 py-10">
    <nav class="text-sm text-gray-500 dark:text-gray-400 mb-6" aria-label="Breadcrumb">
      <a href="/" class="hover:text-blue-600 dark:hover:text-blue-400">Home</a>
      <span class="mx-2">/</span>
      <span class="text-gray-900 dark:text-gray-100 font-medium">How to Get Muscle Fast</span>
    </nav>

    <h1 class="text-3xl font-extrabold tracking-tight mb-2">How to Get Muscle Fast</h1>
    <p class="text-gray-500 dark:text-gray-400 mb-8">The fastest ways to gain muscle &mdash; dumbbell upgrades, pet multipliers, rebirth stacking, and boost strategies.</p>

    <!-- How Muscle Works -->
    <section class="mb-10 p-6 rounded-xl bg-blue-50 dark:bg-blue-950/30 border border-blue-200 dark:border-blue-900">
      <h2 class="text-xl font-bold mb-3">How Muscle Gain Works</h2>
      <div class="text-sm text-gray-600 dark:text-gray-400 space-y-2">
        <p>Every step you take in the game generates muscle. Your total muscle per step is calculated as:</p>
        <div class="p-3 rounded-lg bg-white dark:bg-gray-900 border border-blue-200 dark:border-blue-800 font-mono text-center text-blue-700 dark:text-blue-300 font-bold">
          Base (1) x Dumbbell Multiplier x Pet Muscle Bonus x Rebirth Multiplier x Boost (if active)
        </div>
        <p>All multipliers stack <strong>multiplicatively</strong>. This means upgrading from a 5x dumbbell to a 12x dumbbell while holding a 2x pet at Rebirth Level 1 changes your output from 1 x 5 x 2 x 1.5 = 15 to 1 x 12 x 2 x 1.5 = 36 muscle per step. That is a 2.4x jump from one upgrade.</p>
      </div>
    </section>

    <!-- Dumbbell Upgrade Path -->
    <section class="mb-10">
      <h2 class="text-xl font-bold mb-3 flex items-center gap-2">
        <span class="w-8 h-8 bg-amber-500 text-white rounded-full flex items-center justify-center text-sm font-bold">1</span>
        Dumbbell Upgrade Path
      </h2>
      <p class="text-sm text-gray-600 dark:text-gray-400 mb-4">
        Dumbbells are the most impactful upgrade early on. Each tier dramatically increases your muscle per step. Always upgrade to the next tier as soon as you have enough Wins. Below is the full upgrade path with costs and power levels.
      </p>
      <div class="overflow-x-auto">
        <table class="w-full text-sm border border-gray-200 dark:border-gray-800 rounded-lg overflow-hidden">
          <thead class="bg-gray-50 dark:bg-gray-900">
            <tr>
              <th class="px-4 py-3 text-left font-bold">Dumbbell</th>
              <th class="px-4 py-3 text-center font-bold">Muscle/Step</th>
              <th class="px-4 py-3 text-center font-bold">Cost (Wins)</th>
              <th class="px-4 py-3 text-center font-bold">Cost Efficiency</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
            {dumbbells.map((db, i) => {
              const efficiency = i > 0 ? (db.musclePerStep / db.cost * 100).toFixed(4) : '&mdash;';
              const prevStep = i > 0 ? dumbbells[i - 1].musclePerStep : 0;
              const jump = i > 0 ? (db.musclePerStep / prevStep).toFixed(1) + 'x' : '&mdash;';
              return (
                <tr class={i % 2 === 0 ? 'bg-white dark:bg-gray-950' : 'bg-gray-50 dark:bg-gray-900'}>
                  <td class="px-4 py-3">
                    <span class="font-bold">{db.name}</span>
                    <span class="ml-2 text-xs text-gray-400">Tier {db.tier}</span>
                  </td>
                  <td class="px-4 py-3 text-center font-bold text-blue-600 dark:text-blue-400">{formatNumber(db.musclePerStep)}x</td>
                  <td class="px-4 py-3 text-center text-gray-500 dark:text-gray-400">{db.cost === 0 ? 'Free' : formatNumber(db.cost)}</td>
                  <td class="px-4 py-3 text-center text-gray-500 dark:text-gray-400">{i > 0 ? `${jump} jump` : 'Starter'}</td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
      <p class="text-xs text-gray-400 mt-2">Cost Efficiency shows the multiplier jump from the previous tier. The biggest early jumps are Iron (2x) and Golden (2.4x from Steel).</p>
    </section>

    <!-- Pet Muscle Bonuses -->
    <section class="mb-10">
      <h2 class="text-xl font-bold mb-3 flex items-center gap-2">
        <span class="w-8 h-8 bg-blue-500 text-white rounded-full flex items-center justify-center text-sm font-bold">2</span>
        Best Pets for Muscle Gain
      </h2>
      <p class="text-sm text-gray-600 dark:text-gray-400 mb-4">
        Your equipped pet multiplies every step's muscle output. The top pets for muscle gain offer massive bonuses that stack with dumbbells and rebirth. Here are the top 5 pets ranked by muscle bonus:
      </p>
      <div class="space-y-3">
        {topMusclePets.map((pet, i) => (
          <div class="p-4 rounded-xl border border-gray-200 dark:border-gray-800 flex items-center justify-between">
            <div class="flex items-center gap-3">
              <span class="w-8 h-8 bg-blue-100 dark:bg-blue-900 text-blue-700 dark:text-blue-300 rounded-full flex items-center justify-center text-sm font-bold">#{i + 1}</span>
              <div>
                <span class="font-bold">{pet.name}</span>
                <span class="ml-2 text-xs text-gray-400">{pet.rarity} &middot; {pet.eggSource}</span>
              </div>
            </div>
            <div class="text-center">
              <span class="font-bold text-blue-600 dark:text-blue-400 text-lg">{pet.muscleBonus}x</span>
              <div class="text-xs text-gray-400">Muscle Bonus</div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Rebirth Multiplier Stacking -->
    <section class="mb-10">
      <h2 class="text-xl font-bold mb-3 flex items-center gap-2">
        <span class="w-8 h-8 bg-green-500 text-white rounded-full flex items-center justify-center text-sm font-bold">3</span>
        Rebirth Multiplier Stacking
      </h2>
      <div class="pl-10 text-sm text-gray-600 dark:text-gray-400 space-y-3">
        <p>Rebirth multipliers are the biggest long-term power multiplier in the game. Unlike dumbbells and pets, rebirth bonuses are permanent and require no inventory slot. Each rebirth level compounds with your other multipliers.</p>
        <p><strong>Example at Rebirth Level 10:</strong></p>
        <div class="p-3 rounded-lg bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 font-mono text-sm">
          Universal Dumbbell (5000x) x "67" Pet (50x) x Rebirth 10 (15x) = <strong class="text-blue-600 dark:text-blue-400">3,750,000x</strong> muscle per step
        </div>
        <p><strong>Example at Rebirth Level 17 (max):</strong></p>
        <div class="p-3 rounded-lg bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 font-mono text-sm">
          Universal Dumbbell (5000x) x Huge Hydra Dominus (150x) x Rebirth 17 (200x) = <strong class="text-amber-600 dark:text-amber-400">150,000,000x</strong> muscle per step
        </div>
        <p>The difference between Rebirth 10 and Rebirth 17 is a 13.3x multiplier increase, which is why reaching max rebirth is a game-changing goal. Use our <a href="/rebirth-calculator/" class="text-blue-600 hover:underline">rebirth calculator</a> to plan your rebirth strategy.</p>
      </div>
    </section>

    <!-- Boost Timing -->
    <section class="mb-10 p-6 rounded-xl bg-amber-50 dark:bg-amber-950/20 border border-amber-200 dark:border-amber-900">
      <h2 class="text-xl font-bold mb-3">Boost Timing Strategy</h2>
      <div class="text-sm text-gray-600 dark:text-gray-400 space-y-3">
        <p>Boosts give a temporary 2x multiplier on top of everything else. Proper timing maximizes their value:</p>
        <ul class="list-disc pl-5 space-y-2">
          <li><strong>Boost + New Dumbbell:</strong> Just bought a new dumbbell? Activate a boost right after to double the immediate impact of your upgrade.</li>
          <li><strong>Boost + Rebirth:</strong> Rebirth first, then boost. You regain muscle faster with both multipliers active.</li>
          <li><strong>Boost + Long Session:</strong> Only use boosts when you can play for the full duration. Stepping away wastes precious multiplier time.</li>
          <li><strong>Free Boosts from Codes:</strong> Our <a href="/codes/" class="text-blue-600 hover:underline">codes page</a> lists all active codes that include free boosts. Check it before each play session.</li>
          <li><strong>Auto-Walk:</strong> If the game supports auto-walk or treadmills, activate them during boosts for hands-free muscle gain.</li>
        </ul>
      </div>
    </section>

    <!-- Quick Summary -->
    <section class="mb-10 p-6 rounded-xl bg-green-50 dark:bg-green-950/20 border border-green-200 dark:border-green-900">
      <h2 class="text-xl font-bold mb-3">Quick Muscle Priority List</h2>
      <ol class="space-y-2 text-sm text-gray-600 dark:text-gray-400">
        <li><strong>1.</strong> Upgrade your dumbbell to the next available tier (biggest immediate impact).</li>
        <li><strong>2.</strong> Equip your pet with the highest muscleBonus.</li>
        <li><strong>3.</strong> Rebirth when you have beaten all available opponents.</li>
        <li><strong>4.</strong> Use boosts during dedicated play sessions.</li>
        <li><strong>5.</strong> Redeem <a href="/codes/" class="text-blue-600 hover:underline">free codes</a> for bonus Wins to afford upgrades faster.</li>
      </ol>
    </section>

    <!-- Related Links -->
    <section class="p-6 rounded-xl border border-gray-200 dark:border-gray-800 mb-6">
      <h2 class="text-xl font-bold mb-4">Related Tools &amp; Guides</h2>
      <div class="flex flex-wrap gap-3">
        <a href="/dumbbell-calculator/" class="px-4 py-2 bg-blue-600 text-white rounded-lg font-semibold text-sm hover:bg-blue-700">Dumbbell Calculator</a>
        <a href="/pet-calculator/" class="px-4 py-2 bg-green-600 text-white rounded-lg font-semibold text-sm hover:bg-green-700">Pet Calculator</a>
        <a href="/beginner-guide/" class="px-4 py-2 bg-amber-500 text-white rounded-lg font-semibold text-sm hover:bg-amber-600">Beginner Guide</a>
      </div>
    </section>

    <p class="text-xs text-gray-400 text-center">Last updated: {config.game.lastUpdated}</p>
  </div>
</BaseLayout>
