---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getWorlds, getWorldBySlug, formatNumber, generateBreadcrumbSchema } from '@/lib/data';
import type { GetStaticPaths } from 'astro';
export const getStaticPaths: GetStaticPaths = () => getWorlds().map(w => ({ params: { slug: w.slug }, props: { world: w } }));
const { world } = Astro.props;
const breadcrumbSchema = generateBreadcrumbSchema([{ name: 'Home', url: '/' }, { name: 'Wiki', url: '/wiki' }, { name: world.name, url: `/wiki/${world.slug}` }]);
const DIFF_COLORS: Record<string,string> = { Easy:'bg-green-100 text-green-700', Medium:'bg-yellow-100 text-yellow-700', Hard:'bg-orange-100 text-orange-700', Extreme:'bg-red-100 text-red-700' };
---
<BaseLayout title={`${world.name} — All Opponents | +1 Muscle to Arm Wrestle`} description={`${world.name}: ${world.opponents.length} opponents with muscle requirements.`} canonical={`/wiki/${world.slug}`}>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <div class="max-w-4xl mx-auto px-4 py-10">
    <a href="/wiki/" class="text-sm text-blue-600 hover:underline mb-4 inline-block">← Back to Wiki</a>
    <h1 class="text-3xl font-extrabold mb-2">🌍 {world.name}</h1>
    <p class="text-gray-500 mb-2">{world.description}</p>
    <div class="flex flex-wrap gap-3 text-sm mb-8">
      <span class="px-3 py-1 rounded-full bg-blue-100 text-blue-700">World {world.order} of 4</span>
      <span class="px-3 py-1 rounded-full bg-amber-100 text-amber-700">🔓 {world.unlockRequirement}</span>
    </div>
    <h2 class="text-xl font-bold mb-4">Opponents</h2>
    <div class="space-y-3">
      {world.opponents.map((opp, i) => (
        <div class="p-4 rounded-xl border border-gray-200">
          <div class="flex items-center gap-3 mb-2">
            <span class="w-6 h-6 bg-gray-200 rounded-full flex items-center justify-center text-xs font-bold">{i+1}</span>
            <span class="font-bold">{opp.name}</span>
            <span class={`px-2 py-0.5 rounded text-xs font-bold ${DIFF_COLORS[opp.difficulty]||''}`}>{opp.difficulty}</span>
          </div>
          <p class="text-sm text-gray-500 mb-2">{opp.description}</p>
          <div class="flex gap-4 text-sm">
            <span class="text-gray-400">Muscle: <span class="font-mono font-bold text-amber-500">{formatNumber(opp.muscleRequired)}</span></span>
            <span class="text-gray-400">Wins: <span class="font-mono font-bold text-green-500">{formatNumber(opp.winsReward)}</span></span>
          </div>
        </div>
      ))}
    </div>
    <div class="mt-8 flex flex-wrap gap-3">
      <a href="/wiki/" class="px-4 py-2 bg-blue-600 text-white rounded-lg font-semibold text-sm hover:bg-blue-700">📚 All Worlds</a>
      <a href="/calculator/" class="px-4 py-2 bg-amber-500 text-white rounded-lg font-semibold text-sm hover:bg-amber-600">🧮 Calculator</a>
    </div>
  </div>
</BaseLayout>
