---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getGameConfig, getPets, getDumbbells, formatNumber, generateBreadcrumbSchema, generateFAQSchema, generateVideoGameSchema } from '@/lib/data';

const config = getGameConfig();
const pets = getPets();
const dumbbells = getDumbbells();

const breadcrumbSchema = generateBreadcrumbSchema([
  { name: 'Home', url: '/' },
  { name: 'Pet Calculator', url: '/pet-calculator' },
]);
const faqSchema = generateFAQSchema([
  { question: 'How do pets affect muscle gain in +1 Muscle to Arm Wrestle?', answer: 'Pets provide a muscle bonus multiplier that stacks with your dumbbell base muscle per step and rebirth multiplier. For example, a pet with 2.0x bonus doubles your effective muscle per step.' },
  { question: 'Which pet is the best for muscle gain?', answer: 'The Huge Hydra Dominus (150x) is the strongest pet but requires a Gamepass purchase. Among hatchable pets, 67 (50x) from 67 Packs is the best, followed by Strawberry Elephant (25x) from Strawberry Eggs.' },
  { question: 'Do pet bonuses stack with rebirth multipliers?', answer: 'Yes, pet bonuses multiply with all other bonuses. Your effective muscle per step = Dumbbell base x Rebirth multiplier x Pet multiplier x Boost.' },
]);
const videoGameSchema = generateVideoGameSchema();
---
<BaseLayout title="+1 Muscle to Arm Wrestle Pet Calculator" description="Calculate how pets affect your muscle and wins in +1 Muscle to Arm Wrestle. Compare pet multipliers and find the best pet for your stage." canonical="/pet-calculator/">
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(videoGameSchema)} />

  <div class="max-w-5xl mx-auto px-4 py-10">
    <nav class="text-sm text-gray-400 mb-6" aria-label="Breadcrumb">
      <a href="/" class="hover:text-blue-500">Home</a>
      <span class="mx-2">/</span>
      <span class="text-gray-700 dark:text-gray-200 font-medium">Pet Calculator</span>
    </nav>

    <div class="text-3xl mb-2" aria-hidden="true">馃惥</div>
    <h1 class="text-3xl font-extrabold tracking-tight mb-2">+1 Muscle to Arm Wrestle Pet Calculator</h1>
    <p class="text-gray-500 mb-8">Calculate how pets affect your muscle and wins. Compare pet multipliers and find the best pet for your stage.</p>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      <!-- Side-by-side comparison -->
      <div class="space-y-6">
        <div class="p-4 rounded-xl border bg-gray-50 dark:bg-gray-800 dark:border-gray-700">
          <h2 class="font-bold mb-3">馃攧 Side-by-Side Comparison</h2>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-semibold mb-1" for="pet-a">Pet A</label>
              <select id="pet-a" class="w-full p-2 rounded-lg border border-gray-200 bg-white dark:bg-gray-700 dark:border-gray-600 text-sm">
                <option value="" data:bonus="1" data:winBonus="1">No Pet</option>
                {pets.map(p => (
                  <option value={p.id} data:bonus={p.muscleBonus} data:winBonus={p.winBonus}>
                    {p.name} ({p.rarity})
                  </option>
                ))}
              </select>
            </div>
            <div>
              <label class="block text-sm font-semibold mb-1" for="pet-b">Pet B</label>
              <select id="pet-b" class="w-full p-2 rounded-lg border border-gray-200 bg-white dark:bg-gray-700 dark:border-gray-600 text-sm">
                <option value="" data:bonus="1" data:winBonus="1">No Pet</option>
                {pets.map((p, i) => (
                  <option value={p.id} data:bonus={p.muscleBonus} data:winBonus={p.winBonus} selected={i === pets.length - 1}>
                    {p.name} ({p.rarity})
                  </option>
                ))}
              </select>
            </div>
          </div>
        </div>

        <div>
          <label class="block font-bold mb-2" for="dumbbell-select">馃弸锔?Your Dumbbell</label>
          <select id="dumbbell-select" class="w-full p-3 rounded-lg border border-gray-200 bg-white dark:bg-gray-800 dark:border-gray-700 focus:ring-2 focus:ring-amber-400 outline-none">
            {dumbbells.map(d => (
              <option value={d.id} data:musclePerStep={d.musclePerStep}>
                {d.name} -{d.musclePerStep} muscle/step
              </option>
            ))}
          </select>
        </div>

        <div>
          <label class="block font-bold mb-2" for="rebirth-level">馃攧 Rebirth Level</label>
          <select id="rebirth-level" class="w-full p-3 rounded-lg border border-gray-200 bg-white dark:bg-gray-800 dark:border-gray-700 focus:ring-2 focus:ring-amber-400 outline-none">
            <option value="1">Rebirth 0 -1x</option>
            <option value="1.5">Rebirth 1 -1.5x</option>
            <option value="2">Rebirth 2 -2x</option>
            <option value="3">Rebirth 3 -3x</option>
            <option value="5">Rebirth 5 -5x</option>
            <option value="10">Rebirth 7 -10x</option>
            <option value="15">Rebirth 10 -15x</option>
            <option value="100">Rebirth 15 -100x</option>
            <option value="200">Rebirth 17 -200x</option>
          </select>
        </div>

        <button id="calc-btn" class="w-full py-3 px-6 rounded-xl bg-amber-500 hover:bg-amber-600 text-white font-bold text-lg transition-colors">
          Compare Pets
        </button>

        <!-- Results -->
        <div id="results-panel" class="hidden space-y-4">
          <div class="grid grid-cols-2 gap-3">
            <div class="p-4 rounded-xl bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 text-center">
              <div class="text-xs text-gray-500 mb-1">Pet A -Muscle/Step</div>
              <div id="pet-a-result" class="text-2xl font-black text-blue-500">-</div>
            </div>
            <div class="p-4 rounded-xl bg-purple-50 dark:bg-purple-900/20 border border-purple-200 dark:border-purple-800 text-center">
              <div class="text-xs text-gray-500 mb-1">Pet B -Muscle/Step</div>
              <div id="pet-b-result" class="text-2xl font-black text-purple-500">-</div>
            </div>
          </div>
          <div class="p-4 rounded-xl bg-gray-50 dark:bg-gray-800 border">
            <h3 class="font-bold mb-2">馃搳 Comparison</h3>
            <div class="space-y-2 text-sm">
              <div class="flex justify-between">
                <span class="text-gray-500">Muscle Difference</span>
                <span id="muscle-diff" class="font-mono font-bold">-</span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-500">Win Bonus A</span>
                <span id="win-bonus-a" class="font-mono font-bold">-</span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-500">Win Bonus B</span>
                <span id="win-bonus-b" class="font-mono font-bold">-</span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-500">Steps to 1M Muscle (A)</span>
                <span id="steps-a" class="font-mono font-bold">-</span>
              </div>
              <div class="flex justify-between">
                <span class="text-gray-500">Steps to 1M Muscle (B)</span>
                <span id="steps-b" class="font-mono font-bold">-</span>
              </div>
            </div>
          </div>
          <div id="recommendation-box" class="p-4 rounded-xl bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800">
            <h3 class="font-bold mb-1">馃挕 Verdict</h3>
            <p id="recommendation-text" class="text-sm text-gray-600 dark:text-gray-300"></p>
          </div>
        </div>
      </div>

      <!-- Pet Overview -->
      <div class="space-y-4">
        <h2 class="text-xl font-bold">馃惥 All Pets Ranked by Muscle Bonus</h2>
        <div class="overflow-x-auto">
          <table class="w-full text-sm border-collapse">
            <thead>
              <tr class="bg-gray-100 dark:bg-gray-800">
                <th class="p-3 text-left rounded-tl-lg">Pet</th>
                <th class="p-3 text-left">Rarity</th>
                <th class="p-3 text-right">Muscle</th>
                <th class="p-3 text-right rounded-tr-lg">Wins</th>
              </tr>
            </thead>
            <tbody>
              {pets.sort((a, b) => b.muscleBonus - a.muscleBonus).map((p, i) => (
                <tr class={`border-b border-gray-100 dark:border-gray-800 ${i % 2 === 0 ? 'bg-gray-50 dark:bg-gray-900/50' : ''}`}>
                  <td class="p-3 font-medium">{p.name}</td>
                  <td class="p-3">
                    <span class={`text-xs px-2 py-0.5 rounded-full ${
                      p.rarity === 'Common' ? 'bg-gray-100 text-gray-600 dark:bg-gray-700 dark:text-gray-300' :
                      p.rarity === 'Uncommon' ? 'bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400' :
                      p.rarity === 'Rare' ? 'bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400' :
                      p.rarity === 'Epic' ? 'bg-purple-100 text-purple-700 dark:bg-purple-900/30 dark:text-purple-400' :
                      p.rarity === 'Legendary' ? 'bg-amber-100 text-amber-700 dark:bg-amber-900/30 dark:text-amber-400' :
                      'bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-400'
                    }`}>{p.rarity}</span>
                  </td>
                  <td class="p-3 text-right font-mono">{p.muscleBonus}x</td>
                  <td class="p-3 text-right font-mono">{p.winBonus}x</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <!-- FAQ -->
        <div class="mt-8">
          <h2 class="text-xl font-bold mb-4">Frequently Asked Questions</h2>
          <div class="space-y-3">
            <details class="p-4 rounded-xl bg-gray-50 dark:bg-gray-800 border cursor-pointer">
              <summary class="font-semibold">How do pets affect muscle gain?</summary>
              <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">Pets provide a muscle bonus multiplier that stacks with your dumbbell base muscle per step and rebirth multiplier. For example, a pet with 2.0x bonus doubles your effective muscle per step.</p>
            </details>
            <details class="p-4 rounded-xl bg-gray-50 dark:bg-gray-800 border cursor-pointer">
              <summary class="font-semibold">Which pet is the best for muscle gain?</summary>
              <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">The Huge Hydra Dominus (150x) is the strongest pet but requires a Gamepass purchase. Among hatchable pets, 67 (50x) from 67 Packs is the best, followed by Strawberry Elephant (25x) from Strawberry Eggs.</p>
            </details>
            <details class="p-4 rounded-xl bg-gray-50 dark:bg-gray-800 border cursor-pointer">
              <summary class="font-semibold">Do pet bonuses stack with rebirth multipliers?</summary>
              <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">Yes, pet bonuses multiply with all other bonuses. Your effective muscle per step = Dumbbell base x Rebirth multiplier x Pet multiplier x Boost.</p>
            </details>
          </div>
        </div>
      </div>
    </div>

    <!-- Related Links -->
    <div class="mt-12 pt-8 border-t">
      <h3 class="font-bold mb-4">Useful Links</h3>
      <div class="flex flex-wrap gap-3">
        <a href="/pet-tier-list/" class="px-4 py-2 rounded-lg bg-gray-100 dark:bg-gray-800 hover:bg-amber-100 dark:hover:bg-amber-900/30 font-medium text-sm transition-colors">馃搳 Tier List</a>
        <a href="/muscle-calculator/" class="px-4 py-2 rounded-lg bg-gray-100 dark:bg-gray-800 hover:bg-amber-100 dark:hover:bg-amber-900/30 font-medium text-sm transition-colors">馃М Muscle Calculator</a>
        <a href="/beginner-guide/" class="px-4 py-2 rounded-lg bg-gray-100 dark:bg-gray-800 hover:bg-amber-100 dark:hover:bg-amber-900/30 font-medium text-sm transition-colors">馃摉 Beginner Guide</a>
      </div>
    </div>

    <p class="mt-6 text-xs text-gray-400">Last updated: {config.game.lastUpdated}</p>
  </div>

  <script>
    function formatNumber(num) {
      if (num >= 1e15) return (num / 1e15).toFixed(1) + 'Q';
      if (num >= 1e12) return (num / 1e12).toFixed(1) + 'T';
      if (num >= 1e9) return (num / 1e9).toFixed(1) + 'B';
      if (num >= 1e6) return (num / 1e6).toFixed(1) + 'M';
      if (num >= 1e3) return (num / 1e3).toFixed(1) + 'K';
      return Math.round(num).toString();
    }

    document.getElementById('calc-btn').addEventListener('click', () => {
      const dbSel = document.getElementById('dumbbell-select');
      const dbOpt = dbSel.options[dbSel.selectedIndex];
      const baseMPS = parseFloat(dbOpt.dataset.muscleperstep);

      const rbSel = document.getElementById('rebirth-level');
      const rbMult = parseFloat(rbSel.value);

      const selA = document.getElementById('pet-a');
      const optA = selA.options[selA.selectedIndex];
      const bonusA = parseFloat(optA.dataset.bonus) || 1;
      const winBonusA = parseFloat(optA.dataset.winbonus) || 1;

      const selB = document.getElementById('pet-b');
      const optB = selB.options[selB.selectedIndex];
      const bonusB = parseFloat(optB.dataset.bonus) || 1;
      const winBonusB = parseFloat(optB.dataset.winbonus) || 1;

      const nameA = optA.textContent.trim() || 'No Pet';
      const nameB = optB.textContent.trim() || 'No Pet';

      const mpsA = baseMPS * rbMult * bonusA;
      const mpsB = baseMPS * rbMult * bonusB;

      const panel = document.getElementById('results-panel');
      panel.classList.remove('hidden');

      document.getElementById('pet-a-result').textContent = formatNumber(mpsA);
      document.getElementById('pet-b-result').textContent = formatNumber(mpsB);
      document.getElementById('muscle-diff').textContent = (mpsB > mpsA ? '+' : '') + formatNumber(mpsB - mpsA);
      document.getElementById('win-bonus-a').textContent = winBonusA + 'x';
      document.getElementById('win-bonus-b').textContent = winBonusB + 'x';

      const stepsA = mpsA > 0 ? Math.ceil(1000000 / mpsA) : Infinity;
      const stepsB = mpsB > 0 ? Math.ceil(1000000 / mpsB) : Infinity;
      document.getElementById('steps-a').textContent = stepsA === Infinity ? '-' : formatNumber(stepsA);
      document.getElementById('steps-b').textContent = stepsB === Infinity ? '-' : formatNumber(stepsB);

      let rec = '';
      if (bonusB > bonusA) {
        const improvement = ((bonusB / bonusA - 1) * 100).toFixed(0);
        rec = `${nameB} gives ${improvement}% more muscle per step than ${nameA} (${bonusB}x vs ${bonusA}x). `;
        if (winBonusB > winBonusA) {
          rec += `It also has a better win bonus (${winBonusB}x vs ${winBonusA}x). ${nameB} is the clear winner!`;
        } else if (winBonusB < winBonusA) {
          rec += `However, ${nameA} has a better win bonus (${winBonusA}x vs ${winBonusB}x). Choose based on your priority.`;
        } else {
          rec += 'Win bonuses are equal, so choose the higher muscle bonus.';
        }
      } else if (bonusA > bonusB) {
        const improvement = ((bonusA / bonusB - 1) * 100).toFixed(0);
        rec = `${nameA} gives ${improvement}% more muscle per step than ${nameB} (${bonusA}x vs ${bonusB}x). `;
        if (winBonusA > winBonusB) {
          rec += `It also has a better win bonus (${winBonusA}x vs ${winBonusB}x). ${nameA} is the clear winner!`;
        } else if (winBonusA < winBonusB) {
          rec += `However, ${nameB} has a better win bonus (${winBonusB}x vs ${winBonusA}x). Choose based on your priority.`;
        } else {
          rec += 'Win bonuses are equal, so choose the higher muscle bonus.';
        }
      } else {
        rec = `Both pets have the same muscle bonus (${bonusA}x). `;
        if (winBonusA > winBonusB) {
          rec += `${nameA} wins on win bonus (${winBonusA}x vs ${winBonusB}x).`;
        } else if (winBonusB > winBonusA) {
          rec += `${nameB} wins on win bonus (${winBonusB}x vs ${winBonusA}x).`;
        } else {
          rec += 'They are identical in stats.';
        }
      }
      document.getElementById('recommendation-text').textContent = rec;
    });
  </script>
</BaseLayout>
