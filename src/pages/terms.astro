---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="Terms of Service" description="Terms of service." canonical="/terms">
  <div class="max-w-3xl mx-auto px-4 py-10">
    <h1 class="text-3xl font-extrabold mb-6">Terms of Service</h1>
    <div class="space-y-4 text-sm text-gray-600 dark:text-gray-400">
      <p><strong>Last updated:</strong> May 31, 2026</p>
      <p class="font-bold text-gray-900 dark:text-gray-100">1. Acceptance</p><p>By using this site, you agree to these terms.</p>
      <p class="font-bold text-gray-900 dark:text-gray-100">2. Nature</p><p>Fan-made informational site. Not affiliated with Roblox or Beast Lifters.</p>
      <p class="font-bold text-gray-900 dark:text-gray-100">3. Accuracy</p><p>We strive for accuracy but cannot guarantee all data is current.</p>
      <p class="font-bold text-gray-900 dark:text-gray-100">4. IP</p><p>Game names and content are property of their respective owners.</p>
      <p class="font-bold text-gray-900 dark:text-gray-100">5. Liability</p><p>Site provided "as is" without warranties.</p>
    </div>
  </div>
</BaseLayout>
