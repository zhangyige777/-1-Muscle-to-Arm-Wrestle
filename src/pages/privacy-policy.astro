---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="Privacy Policy" description="Privacy policy." canonical="/privacy-policy">
  <div class="max-w-3xl mx-auto px-4 py-10">
    <h1 class="text-3xl font-extrabold mb-6">Privacy Policy</h1>
    <div class="space-y-4 text-sm text-gray-600 dark:text-gray-400">
      <p><strong>Last updated:</strong> May 31, 2026</p>
      <p class="font-bold text-gray-900 dark:text-gray-100">1. Data Collection</p><p>This static site does not collect personal information.</p>
      <p class="font-bold text-gray-900 dark:text-gray-100">2. Analytics</p><p>We may use Google Analytics for anonymous traffic data.</p>
      <p class="font-bold text-gray-900 dark:text-gray-100">3. Cookies</p><p>Analytics cookies may be set. Disable in browser settings.</p>
      <p class="font-bold text-gray-900 dark:text-gray-100">4. Children</p><p>We do not knowingly collect data from children under 13.</p>
    </div>
  </div>
</BaseLayout>
