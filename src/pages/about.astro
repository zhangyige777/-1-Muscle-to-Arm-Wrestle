---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="About" description="About this fan-made companion site." canonical="/about">
  <div class="max-w-3xl mx-auto px-4 py-10">
    <h1 class="text-3xl font-extrabold mb-6">About This Site</h1>
    <div class="space-y-4 text-sm text-gray-600 dark:text-gray-400">
      <p><strong>+1 Muscle to Arm Wrestle Guide & Tools</strong> is a fan-made companion site for the Roblox game by Beast Lifters.</p>
      <p>Tools: <strong>Codes Tracker</strong> · <strong>Muscle Calculator</strong> · <strong>Pet Tier List</strong> · <strong>Beginner Guide</strong> · <strong>Wiki</strong></p>
      <p class="font-bold text-gray-900 dark:text-gray-100">Disclaimer</p>
      <p>Not affiliated with Roblox Corporation or Beast Lifters. Game content is property of respective owners.</p>
    </div>
    <div class="mt-8 flex gap-3">
      <a href="/" class="px-4 py-2 bg-blue-600 text-white rounded-lg font-semibold text-sm hover:bg-blue-700">🏠 Home</a>
      <a href="https://www.roblox.com/games/134750648450964" target="_blank" rel="noopener noreferrer" class="px-4 py-2 bg-green-600 text-white rounded-lg font-semibold text-sm hover:bg-green-700">▶ Play</a>
    </div>
  </div>
</BaseLayout>
